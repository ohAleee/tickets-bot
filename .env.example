# ---- Discord ----
DISCORD_BOT_TOKEN=
DISCORD_BOT_CLIENT_ID=
DISCORD_BOT_OAUTH_SECRET=
DISCORD_BOT_PUBLIC_KEY=
DISCORD_SUPPORT_SERVER_INVITE=https://discord.gg/ticketsbot

# ---- Access control ----
ADMIN_USER_IDS=
HELPER_USER_IDS=

# ---- Single Postgres instance (hosts ticketsbot + botcache + archive) ----
DATABASE_PASSWORD=changeme

# ---- Redis ----
# Left empty: Redis runs with no password and clients send no AUTH. To enable a password,
# see the note on the redis service in docker-compose.yml.
REDIS_PASSWORD=

# ---- Dashboard ----
DASHBOARD_URL=http://localhost:5000
API_URL=http://localhost:8082
LANDING_PAGE_URL=https://tickets.bot
DOCS_URL=https://docs.tickets.bot
REDIRECT_WEBSITE=https://tickets.bot
INVITE_URL=https://discord.com
JWT_SECRET=changeme-long-random-string
REAL_IP_HEADERS=X-Forwarded-For
TRUSTED_PROXIES=127.0.0.1,172.21.0.1
# http-gateway is the interaction ingress; point Discord's interactions endpoint at it.
INTERACTIONS_BASE_URL=http://http-gateway:4000

# ---- Branding (optional) ----
POWERED_BY=github.com/ticketsbot-cloud
ICON_URL=https://tickets.bot/assets/img/logo.png

# ---- Autoclose sweep (minutes) ----
SWEEP_TIME=10

# ---- Transcripts / archiver ----
ARCHIVER_AES_KEY=
ARCHIVER_ADMIN_AUTH_TOKEN=

# ---- S3 (rustfs) ----
S3_ENDPOINT=http://rustfs:9000
S3_ACCESS=
S3_SECRET=
S3_SECURE=false
S3_ARCHIVE_BUCKET=archive
S3_DATA_IMPORT_BUCKET=data-import
S3_TRANSCRIPT_IMPORT_BUCKET=transcript-import

# ---- Observability (optional) ----
SENTRY_DSN=

# ---- Host user mapping for bind-mounted volumes (optional) ----
UID=
GID=
